ibmcloud_api_key    = "YOUR_API_KEY"
region              = "us-south"
resource_group_name = "your-existing-resource-group"
cluster_name        = "my-openshift-cluster"
ocp_version         = "4.20.15_openshift"
worker_pool_flavor  = "bx2.4x16"
worker_count        = 1
worker_zones        = ["us-south-1", "us-south-2", "us-south-3"]

# Set to "cloud_pak" only if you have an active Cloud Pak entitlement
ocp_entitlement = "cloud_pak"

# Set to true for private-only cluster API access
disable_public_service_endpoint = false

# Restrict inbound traffic to a specific CIDR (e.g., your corporate network)
# allowed_inbound_cidr = "10.0.0.0/8"
